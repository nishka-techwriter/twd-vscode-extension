{
  "name": "twd-extension",
  "displayName": "TWD extension",
  "publisher": "twd-extension",
  "description": "Learning how to write VS Code extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.104.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:markdown",
    "onLanguage:mdx",
    "onLanguage:plaintext"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "demo-view",
          "name": "Демо Панель"
        }
      ]
    },
    "commands": [
      {
        "command": "snippetInserter.insertMySnippet",
        "title": "TWD. Snippet Inserter: Insert My Snippet"
      },
      {
        "command": "snippetInserter.insertMarkdownTable",
        "title": "TWD. Snippet Inserter: Insert Table"
      },
      {
        "command": "snippetInserter.insertMarkdownDetails",
        "title": "TWD. Snippet Inserter: Insert Details"
      },
      {
        "command": "textEditor.wrapInQuotes",
        "title": "TWD. Text Editor: Wrap in « »"
      },
      {
        "command": "textEditor.wrapInBoldTag",
        "title": "TWD. Text Editor: Wrap in <b>"
      },
      {
        "command": "textEditor.toUpperCase",
        "title": "TWD. Text Editor: To UPPERCASE"
      },
      {
        "command": "demo-view.foldCustomBlocks",
        "title": "Свернуть кастомные блоки",
        "category": "Демо"
      },
      {
        "command": "demo-view.unfoldCustomBlocks",
        "title": "Развернуть кастомные блоки",
        "category": "Демо"
      },
      {
        "command": "demo-view.toggleTheme",
        "title": "Переключить тему",
        "category": "Демо"
      },
      {
        "command": "demo-view.insertSnippet",
        "title": "Вставить демо-сниппет",
        "category": "Демо"
      },
      {
        "command": "keyboardLayoutFixer.fixSelectedText",
        "title": "Исправить раскладку клавиатуры (авто)"
      }
    ],
    "keybindings": [
      {
        "command": "snippetInserter.insertMySnippet",
        "key": "ctrl+alt+t",
        "when": "editorTextFocus"
      },
      {
        "command": "textEditor.wrapInQuotes",
        "key": "ctrl+alt+q",
        "when": "editorTextFocus"
      },
      {
        "command": "textEditor.wrapInBoldTag",
        "key": "ctrl+alt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "textEditor.toUpperCase",
        "key": "ctrl+alt+u",
        "when": "editorTextFocus"
      },
      {
        "command": "keyboardLayoutFixer.fixSelectedText",
        "key": "ctrl+shift+l",
        "when": "editorTextFocus"
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/API.json"
      },
      {
        "language": "markdown",
        "path": "./snippets/components.json"
      }
    ],
    "languages": [
      {
        "id": "mermaid",
        "extensions": [
          ".mmd",
          ".mermaid"
        ],
        "configuration": "./syntaxes/mermaid-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mermaid",
        "scopeName": "markdown.mermaid.codeblock",
        "path": "./syntaxes/mermaid.tmLanguage-markdown.json"
      },
      {
        "scopeName": "markdown.mermaid.codeblock",
        "path": "./syntaxes/mermaid.tmLanguage-markdown.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mermaid": "mermaid"
        }
      },
      {
        "scopeName": "mdx.mermaid.codeblock",
        "path": "./syntaxes/mermaid.tmLanguage-mdx.json",
        "injectTo": [
          "source.mdx"
        ],
        "embeddedLanguages": {
          "mdx.embedded.mermaid": "mermaid"
        }
      },
      {
        "language": "mermaid",
        "scopeName": "source.mermaid",
        "path": "./syntaxes/mermaid.tmLanguage.json"
      }
    ]
  },
"scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "vsix": "npm run package && npx vsce package --allow-missing-repository --skip-license"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.104.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.26.1",
    "esbuild": "^0.27.0",
    "eslint": "^9.34.0",
    "typescript": "^5.9.2"
  }
}
